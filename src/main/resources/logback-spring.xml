<?xml version="1.0" encoding="UTF-8"?>

<configuration>

    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Includes correlationId -->
            <pattern>%d{HH:mm:ss} [%X{correlationId}] %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
    PERFORMANCE:
    - Enables async logging to avoid blocking request threads
    - Improves throughput under high load
    -->

    <!-- ASYNC Appender -->
    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="CONSOLE"/>

        <!-- Queue size for buffering logs -->
        <queueSize>5000</queueSize>

        <!-- Discard low-level logs if queue is full -->
        <discardingThreshold>0</discardingThreshold>

        <!-- Never block application threads -->
        <neverBlock>true</neverBlock>
    </appender>

    <!-- Root logger uses ASYNC appender -->
    <root level="INFO">
        <appender-ref ref="ASYNC"/>
    </root>

</configuration>